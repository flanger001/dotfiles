[core]
    excludesfile = "~/Dropbox/Coding/Personal/dotfiles/git/ignore"
    autocrlf = input
    filemode = false

[rebase]
    autosquash = true

[merge]
    conflictstyle = diff3

[color]
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green

[color "status"]
    added = yellow
    changed = green
    untracked = red

[push]
    # default = simple

[url "git@github.com"]
    insteadOf = gh

[url "https://gist.github.com/"]
    insteadOf = gist:

[url "git@bitbucket.org"]
    insteadOf = bb

[include]
    path = "~/Dropbox/Coding/Personal/dotfiles/git/aliases"

[gpg]
    program = gpg
