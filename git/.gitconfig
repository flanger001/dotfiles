[user]
  name = Dave Shaffer
  email = dave.shaffer@gmail.com

[core]
  excludesfile = ~/.gitignore_global
  filemode = false
	autocrlf = input
  # safecrlf = true

[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =

[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true

[color]
  ui = true

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = yellow
  changed = green
  untracked = red

[push]
  default = simple

[url "git@github.com"]
  insteadOf = gh

[url "https://gist.github.com/"]
  insteadOf = gist:

[url "git@bitbucket.org"]
  insteadOf = bb